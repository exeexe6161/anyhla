---
import Layout from "../../layouts/Layout.astro";
import { useTranslations } from "../../i18n/utils";

const t = useTranslations("de");
---

<Layout title={`${t("contact.title")} — Anyhla`} description="Kontakt zu Anyhla">
  <article class="article-page">
    <h1>{t("contact.title")}</h1>
    <p>{t("contact.intro")}</p>
    <p><a href="mailto:info@anyhla.com">{t("contact.email")}</a></p>
    <p><a href="https://www.instagram.com/anyhla" target="_blank" rel="noopener noreferrer">{t("contact.instagram")}</a></p>
  </article>
</Layout>
