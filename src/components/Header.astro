---
import { getLangFromUrl, useTranslations, getLocalizedPath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const pathname = Astro.url.pathname;
const homeHref = `/${lang}/`;
const dePath = getLocalizedPath(pathname, "de");
const enPath = getLocalizedPath(pathname, "en");
---

<header class="header">
  <button
    class="menu-btn"
    type="button"
    aria-label={t("nav.menu")}
    aria-controls="menu-overlay"
    aria-expanded="false"
  >
    <span class="menu-btn-text">{t("nav.menu")}</span>
    <svg
      class="menu-btn-icon"
      width="22"
      height="22"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"
      aria-hidden="true"
    >
      <path d="M4 7 L20 7" />
      <path d="M4 12 L20 12" />
      <path d="M4 17 L20 17" />
    </svg>
  </button>
  <a href={homeHref} class="wordmark" aria-label={`Anyhla — ${t("nav.home")}`}>
    <svg
      viewBox="-50 -60 4174 820"
      preserveAspectRatio="xMidYMid meet"
      fill="currentColor"
      role="img"
      aria-label="Anyhla"
    >
      <g fill-rule="evenodd">
        <path transform="translate(0,0)" d="M67 580 L257 0 L371 0 L600 700 L533 700 L473 514 L155 514 L134 580 Z M173 456 L455 456 L320 38 L308 38 Z"/>
        <path transform="translate(698,0)" d="M86 700 L86 0 L213 0 L499 662 L511 662 L511 0 L575 0 L575 700 L448 700 L162 37 L150 37 L150 700 Z"/>
        <path transform="translate(1429,0)" d="M270 700 L270 423 L16 0 L92 0 L296 350 L308 350 L512 0 L588 0 L334 423 L334 700 Z"/>
        <path transform="translate(2103,0)" d="M86 700 L86 0 L150 0 L150 320 L506 320 L506 0 L570 0 L570 700 L506 700 L506 378 L150 378 L150 700 Z"/>
        <path transform="translate(2829,0)" d="M86 700 L86 0 L150 0 L150 642 L518 642 L518 700 Z"/>
        <path transform="translate(3446,0)" d="M67 580 L257 0 L371 0 L600 700 L533 700 L473 514 L155 514 L134 580 Z M173 456 L455 456 L320 38 L308 38 Z"/>
      </g>
    </svg>
  </a>
  <div class="header-right">
    <div class="lang-switch" role="group" aria-label={t("lang.switch.label")}>
      <a
        href={dePath}
        hreflang="de"
        class:list={["lang-link", lang === "de" && "active"]}
        aria-current={lang === "de" ? "true" : undefined}
      >DE</a>
      <span class="divider" aria-hidden="true">|</span>
      <a
        href={enPath}
        hreflang="en"
        class:list={["lang-link", lang === "en" && "active"]}
        aria-current={lang === "en" ? "true" : undefined}
      >EN</a>
    </div>
    <a href={`/${lang}/kontakt/`} class="ig-link" aria-label={t("nav.contact")}>
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <rect x="3" y="3" width="18" height="18" rx="5" />
        <circle cx="12" cy="12" r="4" />
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
      </svg>
    </a>
  </div>
</header>
