---

<header class="header">
  <button
    class="menu-btn"
    type="button"
    aria-label="Menü öffnen"
    aria-controls="menu-overlay"
    aria-expanded="false"
  >Menü</button>
  <a href="/" class="wordmark" aria-label="Anyhla Startseite">
    <img src="/brand/anyhla-wordmark.svg" alt="Anyhla" />
  </a>
  <a href="/contact" class="ig-link" aria-label="Kontakt">
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <rect x="3" y="3" width="18" height="18" rx="5" />
      <circle cx="12" cy="12" r="4" />
      <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
    </svg>
  </a>
</header>
