---
import { getLangFromUrl, useTranslations, getLocalizedPath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const pathname = Astro.url.pathname;
const homeHref = `/${lang}/`;
const dePath = getLocalizedPath(pathname, "de");
const enPath = getLocalizedPath(pathname, "en");
---

<header class="header">
  <button
    class="menu-btn"
    type="button"
    aria-label={t("nav.menu")}
    aria-controls="menu-overlay"
    aria-expanded="false"
  >
    <span class="menu-btn-text">{t("nav.menu")}</span>
    <svg
      class="menu-btn-icon"
      width="22"
      height="22"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"
      aria-hidden="true"
    >
      <path d="M4 7 L20 7" />
      <path d="M4 12 L20 12" />
      <path d="M4 17 L20 17" />
    </svg>
  </button>
  <a href={homeHref} class="wordmark" aria-label={`Anyhla — ${t("nav.home")}`}>
    <svg
      viewBox="-100 -120 6958 2000"
      preserveAspectRatio="xMidYMid meet"
      fill="currentColor"
      role="img"
      aria-label="Anyhla"
    >
      <g fill-rule="evenodd">
        <path transform="translate(0,0)" d="M30 1760 L195 110 L350 0 H797 L964 1760 H631 L606 1476 H394 L372 1760 Z M419 1195 H579 L502 300 H486 Z"/>
        <path transform="translate(1194,0)" d="M78 1760V0H440L602 843V0H942V1760H598L422 880V1760Z"/>
        <path transform="translate(2414,0)" d="M291 1760V1181L10 0H359L457 596L555 0H903L623 1181V1760Z"/>
        <path transform="translate(3528,0)" d="M78 1760V0H428V629H594V0H944V1760H594V962H428V1760Z"/>
        <path transform="translate(4750,0)" d="M78 1760V0H430V1460H792V1760Z"/>
        <path transform="translate(5764,0)" d="M30 1760 200 0H797L964 1760H631L606 1476H394L372 1760ZM419 1195H579L502 300H486Z"/>
      </g>
    </svg>
  </a>
  <div class="header-right">
    <div class="lang-switch" role="group" aria-label={t("lang.switch.label")}>
      <a
        href={dePath}
        hreflang="de"
        class:list={["lang-link", lang === "de" && "active"]}
        aria-current={lang === "de" ? "true" : undefined}
      >DE</a>
      <span class="divider" aria-hidden="true">|</span>
      <a
        href={enPath}
        hreflang="en"
        class:list={["lang-link", lang === "en" && "active"]}
        aria-current={lang === "en" ? "true" : undefined}
      >EN</a>
    </div>
    <a href={`/${lang}/contact/`} class="ig-link" aria-label={t("nav.contact")}>
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <rect x="3" y="3" width="18" height="18" rx="5" />
        <circle cx="12" cy="12" r="4" />
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
      </svg>
    </a>
  </div>
</header>
